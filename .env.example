# ============================================================
# Indexer Qdrant pour les datasets
# https://huggingface.co/AgentPublic/datasets
# Copiez ce fichier dans .env et compléte les infos.
# ============================================================

# URL de votre instance Qdrant
# adresse locale par défaut:
QDRANT_URL=http://localhost:6333

# HuggingFace token (optionnel, seulement pour les datasets privés/gated)
HF_TOKEN=
